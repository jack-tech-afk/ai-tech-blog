---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

{/* FAQ Schema JSON-LD */}
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<div class="my-10 rounded-2xl overflow-hidden bg-gray-800 border border-gray-700/50 shadow-xl">
  {/* Header */}
  <div class="bg-gradient-to-r from-indigo-800 to-purple-800 px-6 py-4">
    <h3 class="text-lg font-bold text-white flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      よくある質問（FAQ）
    </h3>
  </div>

  {/* FAQ Items */}
  <div class="divide-y divide-gray-700/50">
    {items.map((item) => (
      <div class="px-6 py-5">
        {/* Question */}
        <div class="flex items-start gap-3 mb-3">
          <span class="inline-flex items-center justify-center w-7 h-7 rounded-lg bg-indigo-600 text-white text-xs font-bold flex-shrink-0 mt-0.5">
            Q
          </span>
          <p class="text-white font-semibold text-base leading-relaxed">{item.question}</p>
        </div>
        {/* Answer */}
        <div class="flex items-start gap-3 ml-0 sm:ml-10">
          <span class="inline-flex items-center justify-center w-7 h-7 rounded-lg bg-green-600 text-white text-xs font-bold flex-shrink-0 mt-0.5">
            A
          </span>
          <p class="text-gray-300 text-sm leading-relaxed">{item.answer}</p>
        </div>
      </div>
    ))}
  </div>
</div>
