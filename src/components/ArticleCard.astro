---
interface Props {
  title: string;
  description: string;
  pubDate: string;
  category: string;
  slug: string;
  tags?: string[];
}

const { title, description, pubDate, category, slug, tags = [] } = Astro.props;

const categoryLabels: Record<string, string> = {
  'ai-tools': 'AIツール',
  'saas': 'SaaS',
  'gadgets': 'ガジェット',
  'guides': '使い方ガイド',
  'ranking': 'ランキング',
  'AIツール': 'AIツール',
  'SaaS': 'SaaS',
  'ガジェット': 'ガジェット',
  '使い方ガイド': '使い方ガイド',
  'ランキング': 'ランキング',
};

const categoryConfig: Record<string, { gradient: string; icon: string; badge: string }> = {
  'ai-tools': {
    gradient: 'from-blue-500 via-blue-600 to-indigo-600',
    icon: '🤖',
    badge: 'bg-blue-500/90 text-white',
  },
  'saas': {
    gradient: 'from-emerald-500 via-teal-500 to-cyan-600',
    icon: '☁️',
    badge: 'bg-emerald-500/90 text-white',
  },
  'gadgets': {
    gradient: 'from-purple-500 via-violet-500 to-fuchsia-600',
    icon: '📱',
    badge: 'bg-purple-500/90 text-white',
  },
  'guides': {
    gradient: 'from-amber-400 via-orange-500 to-red-500',
    icon: '📖',
    badge: 'bg-amber-500/90 text-white',
  },
  'ranking': {
    gradient: 'from-rose-500 via-pink-500 to-red-600',
    icon: '🏆',
    badge: 'bg-rose-500/90 text-white',
  },
  'AIツール': {
    gradient: 'from-blue-500 via-blue-600 to-indigo-600',
    icon: '🤖',
    badge: 'bg-blue-500/90 text-white',
  },
  'SaaS': {
    gradient: 'from-emerald-500 via-teal-500 to-cyan-600',
    icon: '☁️',
    badge: 'bg-emerald-500/90 text-white',
  },
  'ガジェット': {
    gradient: 'from-purple-500 via-violet-500 to-fuchsia-600',
    icon: '📱',
    badge: 'bg-purple-500/90 text-white',
  },
  '使い方ガイド': {
    gradient: 'from-amber-400 via-orange-500 to-red-500',
    icon: '📖',
    badge: 'bg-amber-500/90 text-white',
  },
  'ランキング': {
    gradient: 'from-rose-500 via-pink-500 to-red-600',
    icon: '🏆',
    badge: 'bg-rose-500/90 text-white',
  },
};

const config = categoryConfig[category] || {
  gradient: 'from-gray-500 to-gray-600',
  icon: '📝',
  badge: 'bg-gray-500/90 text-white',
};

const formattedDate = new Date(pubDate).toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="article-card group">
  <a href={`/${slug}`} class="block">
    <!-- Card Hero with Gradient -->
    <div class={`article-card-hero bg-gradient-to-br ${config.gradient}`}>
      <div class="absolute inset-0 opacity-20" style="background-image: url(\"data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 20.5V18H0v-2h20v-2H0v-2h20v-2H0V8h20V6H0V4h20V2H0V0h22v20h2V0h2v20h2V0h2v20h2V0h2v20h2V0h2v20.5z' fill='%23fff' fill-opacity='.08' fill-rule='evenodd'/%3E%3C/svg%3E\")"></div>
      <div class="absolute top-3 left-3">
        <span class={`category-badge ${config.badge} backdrop-blur-sm shadow-sm`}>
          <span>{config.icon}</span>
          {categoryLabels[category] || category}
        </span>
      </div>
      <div class="card-icon">{config.icon}</div>
    </div>

    <!-- Card Body -->
    <div class="article-card-body">
      <div class="flex items-center gap-2 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        <time class="text-xs text-gray-400 font-medium" datetime={pubDate}>{formattedDate}</time>
      </div>

      <h3 class="text-base font-bold text-gray-800 mb-2 line-clamp-2 group-hover:text-primary-600 transition-colors leading-snug">
        {title}
      </h3>
      <p class="text-sm text-gray-500 line-clamp-2 mb-3 leading-relaxed">{description}</p>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.slice(0, 3).map((tag) => (
            <span class="text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full font-medium">#{tag}</span>
          ))}
        </div>
      )}

      <!-- Read More -->
      <div class="mt-4 pt-3 border-t border-gray-100 flex items-center justify-between">
        <span class="text-xs font-semibold text-primary-600 group-hover:text-primary-700 flex items-center gap-1">
          記事を読む
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </span>
      </div>
    </div>
  </a>
</article>
