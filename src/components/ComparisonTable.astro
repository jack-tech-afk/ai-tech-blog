---
interface ComparisonItem {
  rank: number;
  name: string;
  price: string;
  feature: string;
  japaneseSupport: string;
  planType: string;
  rating: number;
}

interface Props {
  items: ComparisonItem[];
}

const { items } = Astro.props;

function getRankBadge(rank: number): { bg: string; text: string; label: string } {
  switch (rank) {
    case 1:
      return { bg: 'bg-gradient-to-r from-yellow-500 to-amber-400', text: 'text-white', label: '1位' };
    case 2:
      return { bg: 'bg-gradient-to-r from-gray-300 to-gray-400', text: 'text-gray-800', label: '2位' };
    case 3:
      return { bg: 'bg-gradient-to-r from-amber-600 to-amber-700', text: 'text-white', label: '3位' };
    default:
      return { bg: 'bg-gray-600', text: 'text-white', label: `${rank}位` };
  }
}

function renderStars(rating: number): string {
  const full = Math.floor(rating);
  const hasHalf = rating % 1 >= 0.5;
  const empty = 5 - full - (hasHalf ? 1 : 0);
  return '★'.repeat(full) + (hasHalf ? '☆' : '') + '☆'.repeat(empty);
}
---

<div class="my-10 rounded-2xl overflow-hidden shadow-xl border border-gray-700/50">
  <!-- Header -->
  <div class="bg-gradient-to-r from-indigo-800 via-indigo-700 to-purple-800 px-6 py-4">
    <h3 class="text-lg font-bold text-white flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
      比較一覧表
    </h3>
  </div>

  <!-- Table -->
  <div class="overflow-x-auto">
    <table class="w-full text-sm" style="border-collapse: collapse;">
      <thead>
        <tr class="bg-gray-800 text-gray-300 text-xs uppercase tracking-wider">
          <th class="px-4 py-3 text-center font-semibold" style="border: none;">順位</th>
          <th class="px-4 py-3 text-left font-semibold" style="border: none;">サービス名</th>
          <th class="px-4 py-3 text-left font-semibold" style="border: none;">料金</th>
          <th class="px-4 py-3 text-left font-semibold" style="border: none;">特徴</th>
          <th class="px-4 py-3 text-center font-semibold" style="border: none;">日本語対応</th>
          <th class="px-4 py-3 text-center font-semibold" style="border: none;">プラン</th>
          <th class="px-4 py-3 text-center font-semibold" style="border: none;">評価</th>
        </tr>
      </thead>
      <tbody>
        {items.map((item, index) => {
          const badge = getRankBadge(item.rank);
          return (
            <tr class={`border-b border-gray-700/50 transition-colors ${index % 2 === 0 ? 'bg-gray-900' : 'bg-gray-800/70'} hover:bg-indigo-900/30`}>
              <td class="px-4 py-4 text-center" style="border: none;">
                <span class={`inline-flex items-center justify-center w-8 h-8 rounded-full text-xs font-bold ${badge.bg} ${badge.text} shadow-sm`}>
                  {badge.label}
                </span>
              </td>
              <td class="px-4 py-4 font-bold text-white" style="border: none;">{item.name}</td>
              <td class="px-4 py-4 text-gray-300" style="border: none;">{item.price}</td>
              <td class="px-4 py-4 text-gray-300 max-w-xs" style="border: none;">{item.feature}</td>
              <td class="px-4 py-4 text-center" style="border: none;">
                <span class="text-sm">{item.japaneseSupport}</span>
              </td>
              <td class="px-4 py-4 text-center" style="border: none;">
                {item.planType === '無料有' ? (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-500/20 text-green-400 border border-green-500/30">
                    無料有
                  </span>
                ) : (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-amber-500/20 text-amber-400 border border-amber-500/30">
                    有料
                  </span>
                )}
              </td>
              <td class="px-4 py-4 text-center" style="border: none;">
                <div class="flex flex-col items-center gap-1">
                  <span class="text-amber-400 text-xs tracking-tight">{renderStars(item.rating)}</span>
                  <span class="text-xs text-gray-400 font-medium">{item.rating.toFixed(1)}</span>
                </div>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
</div>
