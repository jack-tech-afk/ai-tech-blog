---
interface DetailItem {
  label: string;
  value: string;
}

interface Props {
  productName: string;
  rating: number;
  reviewCount: number;
  details: DetailItem[];
}

const { productName, rating, reviewCount, details } = Astro.props;

const fullStars = Math.floor(rating);
const hasHalf = rating % 1 >= 0.5;
const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://ai-tech-review.company';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: productName,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: rating.toString(),
    bestRating: '5',
    worstRating: '1',
    reviewCount: reviewCount.toString(),
  },
  review: {
    '@type': 'Review',
    author: {
      '@type': 'Organization',
      name: 'AI Tech Review',
    },
    reviewRating: {
      '@type': 'Rating',
      ratingValue: rating.toString(),
      bestRating: '5',
    },
    publisher: {
      '@type': 'Organization',
      name: 'AI Tech Review',
      url: siteUrl,
    },
  },
};
---

{/* Product + Review JSON-LD */}
<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<div class="my-8 rounded-2xl overflow-hidden bg-gray-800 border border-gray-700/50 shadow-xl">
  {/* Header */}
  <div class="bg-gradient-to-r from-indigo-800 to-purple-800 px-6 py-4">
    <h3 class="text-lg font-bold text-white flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
      </svg>
      {productName} 総合評価
    </h3>
  </div>

  <div class="p-6">
    {/* Rating Display */}
    <div class="flex items-center gap-6 mb-6">
      {/* Score */}
      <div class="flex flex-col items-center">
        <span class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-orange-400">
          {rating.toFixed(1)}
        </span>
        <span class="text-xs text-gray-400 mt-1">/ 5.0</span>
      </div>

      {/* Stars */}
      <div class="flex flex-col gap-2">
        <div class="flex items-center gap-1">
          {Array.from({ length: fullStars }).map(() => (
            <svg class="w-6 h-6 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
          {hasHalf && (
            <svg class="w-6 h-6 text-amber-400" viewBox="0 0 20 20">
              <defs>
                <linearGradient id="half-star-review">
                  <stop offset="50%" stop-color="currentColor"/>
                  <stop offset="50%" stop-color="#4b5563"/>
                </linearGradient>
              </defs>
              <path fill="url(#half-star-review)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          )}
          {Array.from({ length: emptyStars }).map(() => (
            <svg class="w-6 h-6 text-gray-600" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <span class="text-sm text-gray-400">{reviewCount}件のレビューに基づく</span>
      </div>
    </div>

    {/* Details Grid */}
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {details.map((detail) => (
        <div class="bg-gray-700/50 rounded-xl px-4 py-3 border border-gray-600/30">
          <span class="text-xs text-gray-400 block mb-1">{detail.label}</span>
          <span class="text-sm text-white font-semibold">{detail.value}</span>
        </div>
      ))}
    </div>
  </div>
</div>
