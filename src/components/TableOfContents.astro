---
interface Props {
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="my-8 p-5 bg-gray-50 border border-gray-200 rounded-lg">
    <h2 class="font-bold text-gray-800 mb-3 text-sm uppercase tracking-wide">目次</h2>
    <ol class="space-y-1.5">
      {filteredHeadings.map((heading) => (
        <li class={heading.depth === 3 ? 'ml-4' : ''}>
          <a
            href={`#${heading.slug}`}
            class="text-sm text-gray-600 hover:text-primary-600 transition-colors"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}
