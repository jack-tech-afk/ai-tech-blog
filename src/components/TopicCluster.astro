---
interface ClusterItem {
  title: string;
  url: string;
}

interface Props {
  pillarTitle: string;
  pillarDescription: string;
  clusters: ClusterItem[];
}

const { pillarTitle, pillarDescription, clusters } = Astro.props;
---

<div class="my-10 rounded-2xl overflow-hidden bg-gray-800 border border-gray-700/50 shadow-xl">
  {/* Header */}
  <div class="bg-gradient-to-r from-indigo-800 to-purple-800 px-6 py-4">
    <h3 class="text-lg font-bold text-white flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
      </svg>
      関連トピック
    </h3>
  </div>

  <div class="p-6">
    {/* Pillar Page */}
    <div class="text-center mb-6">
      <div class="inline-flex flex-col items-center bg-gradient-to-br from-indigo-600 to-purple-600 rounded-xl px-6 py-4 shadow-lg">
        <span class="text-xs text-indigo-200 font-semibold uppercase tracking-wider mb-1">ピラーページ</span>
        <span class="text-white font-bold text-lg">{pillarTitle}</span>
        <span class="text-indigo-200 text-xs mt-1">{pillarDescription}</span>
      </div>
    </div>

    {/* Arrows */}
    <div class="flex justify-center mb-4">
      <div class="flex flex-col items-center gap-1">
        <div class="w-0.5 h-4 bg-indigo-500/50"></div>
        <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </div>
    </div>

    {/* Cluster Pages */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {clusters.map((cluster) => (
        <a
          href={cluster.url}
          class="flex items-center gap-3 bg-gray-700/50 hover:bg-indigo-900/30 border border-gray-600/50 hover:border-indigo-500/50 rounded-xl px-4 py-3 transition-all duration-200 group"
        >
          <svg class="w-4 h-4 text-indigo-400 flex-shrink-0 group-hover:text-indigo-300 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <span class="text-sm text-gray-300 group-hover:text-white font-medium transition-colors">{cluster.title}</span>
        </a>
      ))}
    </div>
  </div>
</div>
