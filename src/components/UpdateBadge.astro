---
interface Props {
  pubDate: string;
  updatedDate?: string;
  author?: string;
}

const { pubDate, updatedDate, author = 'AI Tech Review 編集部' } = Astro.props;

const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<div class="my-6 rounded-xl overflow-hidden bg-gray-800 border border-gray-700/50 shadow-md">
  <div class="px-5 py-4 flex flex-wrap items-center gap-x-6 gap-y-2">
    {/* Published Date */}
    <div class="flex items-center gap-2 text-sm text-gray-400">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      <span>公開日: {formatDate(pubDate)}</span>
    </div>

    {/* Updated Date */}
    {updatedDate && (
      <div class="flex items-center gap-2 text-sm">
        <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
        <span class="font-semibold text-green-400">更新日: {formatDate(updatedDate)}</span>
      </div>
    )}

    {/* Author */}
    <div class="flex items-center gap-2 text-sm text-gray-400 ml-auto">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
      <span>{author}</span>
    </div>
  </div>
</div>
