---
import BaseLayout from '../layouts/BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import AffiliateBox from '../components/AffiliateBox.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const formattedDate = new Date(post.data.pubDate).toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryLabels: Record<string, string> = {
  'ai-tools': 'AIツール',
  'saas': 'SaaS',
  'gadgets': 'ガジェット',
  'guides': '使い方ガイド',
  'ranking': 'ランキング',
};

const categoryColors: Record<string, string> = {
  'ai-tools': 'bg-blue-100 text-blue-700',
  'saas': 'bg-green-100 text-green-700',
  'gadgets': 'bg-purple-100 text-purple-700',
  'guides': 'bg-yellow-100 text-yellow-700',
  'ranking': 'bg-red-100 text-red-700',
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  article={true}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
>
  <article class="max-w-3xl mx-auto px-4 py-10">
    <!-- Article Header -->
    <header class="mb-8">
      <div class="flex items-center gap-2 mb-4">
        <span class={`text-xs font-medium px-2.5 py-0.5 rounded-full ${categoryColors[post.data.category] || 'bg-gray-100 text-gray-700'}`}>
          {categoryLabels[post.data.category] || post.data.category}
        </span>
        <time class="text-sm text-gray-500" datetime={post.data.pubDate}>{formattedDate}</time>
        {post.data.updatedDate && (
          <span class="text-sm text-gray-400">
            (更新: {new Date(post.data.updatedDate).toLocaleDateString('ja-JP')})
          </span>
        )}
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">
        {post.data.title}
      </h1>
      <p class="text-lg text-gray-600">{post.data.description}</p>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag: string) => (
            <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <!-- Table of Contents -->
    <TableOfContents headings={headings} />

    <!-- Article Body -->
    <div class="prose max-w-none">
      <Content />
    </div>

    <!-- Affiliate Boxes -->
    {post.data.affiliate && post.data.affiliate.length > 0 && (
      <div class="mt-10 pt-8 border-t border-gray-200">
        <h2 class="text-xl font-bold text-gray-800 mb-4">この記事で紹介した製品・サービス</h2>
        {post.data.affiliate.map((item) => (
          <AffiliateBox
            name={item.name}
            url={item.url}
            price={item.price}
            rating={item.rating}
          />
        ))}
      </div>
    )}

    <!-- Share & Navigation -->
    <div class="mt-10 pt-6 border-t border-gray-200 flex justify-between items-center">
      <a href="/" class="text-primary-600 hover:text-primary-800 font-medium text-sm">
        ← 記事一覧に戻る
      </a>
    </div>
  </article>
</BaseLayout>
