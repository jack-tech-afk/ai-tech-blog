---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const sceneDefinitions = [
  { id: 'presentation', label: 'Presentations', icon: '📊', gradient: 'from-blue-600 via-indigo-600 to-purple-700', tags: ['presentation', 'Gamma', 'Canva', 'Beautiful.ai', 'Tome', 'slides'], description: 'Create stunning presentations with AI. Learn to use Gamma, Canva AI, Copilot and more.' },
  { id: 'meeting', label: 'Meetings & Notes', icon: '📝', gradient: 'from-emerald-600 via-green-600 to-teal-700', tags: ['meeting', 'Otter', 'Fireflies', 'tl;dv', 'Zoom', 'agenda', 'transcription'], description: 'AI meeting notes, summaries, and agenda creation. Boost meeting productivity with AI tools.' },
  { id: 'email', label: 'Email Productivity', icon: '✉️', gradient: 'from-amber-500 via-orange-500 to-red-600', tags: ['email', 'Gmail', 'Outlook', 'template', 'writing'], description: 'Draft professional emails in seconds with AI. Gmail AI, Outlook Copilot, and template guides.' },
  { id: 'idea', label: 'Brainstorming', icon: '💡', gradient: 'from-yellow-500 via-amber-500 to-orange-600', tags: ['brainstorming', 'ideation', 'mind map', 'Miro', 'creativity'], description: 'AI-powered brainstorming, mind mapping, and structured ideation techniques.' },
  { id: 'data', label: 'Data Analysis', icon: '📈', gradient: 'from-cyan-600 via-blue-600 to-indigo-700', tags: ['Excel', 'data', 'Google Sheets', 'dashboard', 'visualization', 'chart', 'spreadsheet'], description: 'Excel Copilot, Google Sheets AI, dashboard creation — analyze data without coding.' },
  { id: 'report', label: 'Reports & Docs', icon: '📋', gradient: 'from-slate-600 via-gray-600 to-zinc-700', tags: ['report', 'daily', 'documentation', 'weekly', 'proposal'], description: 'Automate daily reports, proposals, and business documents with AI templates.' },
  { id: 'support', label: 'Customer Support', icon: '🎧', gradient: 'from-pink-500 via-rose-500 to-red-600', tags: ['customer', 'support', 'chatbot', 'Zendesk', 'Intercom'], description: 'AI chatbots, auto-reply systems, and ticket management for customer support teams.' },
  { id: 'collaboration', label: 'Chat & Collab', icon: '💬', gradient: 'from-violet-600 via-purple-600 to-fuchsia-700', tags: ['Slack', 'Teams', 'Notion', 'collaboration', 'chat', 'productivity'], description: 'Slack AI, Teams Copilot, Notion AI — boost team collaboration with AI-powered tools.' },
  { id: 'writing', label: 'SEO & Writing', icon: '✍️', gradient: 'from-green-600 via-emerald-600 to-teal-700', tags: ['SEO', 'copywriting', 'writing', 'content', 'document review', 'proofreading'], description: 'AI-powered SEO writing, copywriting, document review, and content optimization guides.' },
  { id: 'remote', label: 'Remote Work', icon: '🏠', gradient: 'from-sky-500 via-blue-600 to-indigo-700', tags: ['remote', 'distributed', 'async', 'virtual'], description: 'AI tools for remote teams. Video meetings, async communication, and productivity optimization.' },
];

export function getStaticPaths() {
  return ['presentation', 'meeting', 'email', 'idea', 'data', 'report', 'support', 'collaboration', 'writing', 'remote'].map((scene) => ({ params: { scene } }));
}

const { scene } = Astro.params;
const sceneDef = sceneDefinitions.find((s) => s.id === scene)!;

const allPosts = await getCollection('blogEn');
const scenePosts = allPosts
  .filter((post) => post.data.category === 'business' && sceneDef.tags.some((tag) => post.data.tags?.some((t: string) => t.toLowerCase().includes(tag.toLowerCase()))))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const allBusinessPosts = allPosts
  .filter((post) => post.data.category === 'business')
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const displayPosts = scenePosts.length >= 3 ? scenePosts : allBusinessPosts;
const isShowingAll = scenePosts.length < 3;
---

<BaseLayout
  title={`AI for ${sceneDef.label} | Business AI Guide | AI Tech Review`}
  description={sceneDef.description}
  lang="en"
>
  <!-- Hero -->
  <section class={`relative bg-gradient-to-br ${sceneDef.gradient} text-white py-16 overflow-hidden`}>
    <div class="max-w-5xl mx-auto px-4 text-center relative z-10">
      <span class="text-5xl mb-4 block">{sceneDef.icon}</span>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">
        {sceneDef.label}
      </h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto leading-relaxed">
        {sceneDef.description}
      </p>
      <div class="mt-4 inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm text-sm font-medium px-4 py-2 rounded-full">
        {scenePosts.length} articles
      </div>
    </div>
  </section>

  <!-- Scene Navigation -->
  <section class="max-w-5xl mx-auto px-4 py-6">
    <div class="flex flex-wrap gap-2">
      {sceneDefinitions.map((s) => (
        <a
          href={`/en/business/${s.id}`}
          class={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border text-sm font-medium transition-all ${
            s.id === scene
              ? 'bg-slate-800 border-slate-800 text-white'
              : 'bg-slate-50 border-slate-200 text-slate-600 hover:border-slate-500 hover:bg-slate-100'
          }`}
        >
          <span>{s.icon}</span>
          {s.label}
        </a>
      ))}
    </div>
  </section>

  <!-- Articles -->
  <section class="max-w-5xl mx-auto px-4 py-8">
    {isShowingAll && (
      <p class="text-sm text-gray-500 mb-6">Showing all business articles as this scene has fewer dedicated articles.</p>
    )}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {displayPosts.map((post) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          slug={`en/${post.id}`}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>

  <!-- Back Navigation -->
  <section class="max-w-5xl mx-auto px-4 py-8">
    <a href="/en" class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-800 font-semibold text-sm transition-colors group">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Back to All Articles
    </a>
  </section>
</BaseLayout>
