---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const beginnerPosts = allPosts
  .filter((post) => post.data.tags?.includes('初心者'))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const toolGroups = [
  { id: 'chatgpt', label: 'ChatGPT', icon: '💬' },
  { id: 'claude', label: 'Claude', icon: '🟠' },
  { id: 'gemini', label: 'Gemini', icon: '✨' },
  { id: 'copilot', label: 'Copilot', icon: '🔷' },
  { id: 'midjourney', label: 'Midjourney', icon: '🎨' },
  { id: 'dall-e', label: 'DALL-E', icon: '🖼️' },
  { id: 'perplexity', label: 'Perplexity', icon: '🔍' },
  { id: 'cursor', label: 'Cursor', icon: '⌨️' },
];
---

<BaseLayout
  title="AI初心者ガイド｜はじめてのAIツール活用マップ"
  description="AI初心者向けガイド。ChatGPT、Claude、Gemini、Midjourney等の使い方を基礎からわかりやすく解説。"
>
  <!-- Compact Hero -->
  <section class="bg-gradient-to-br from-green-600 to-teal-700 text-white py-10">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h1 class="text-2xl md:text-3xl font-bold mb-2">
        🔰 AI初心者ガイド
      </h1>
      <p class="text-sm text-green-100/90">
        はじめてAIを使う方へ。{beginnerPosts.length}本の入門記事をツール別に探せます。
      </p>
    </div>
  </section>

  <!-- Tool Navigation (compact) -->
  <section class="max-w-5xl mx-auto px-4 py-6">
    <h2 class="text-lg font-bold text-gray-800 mb-3">ツール別に探す</h2>
    <div class="flex flex-wrap gap-2">
      {toolGroups.map((tool) => (
        <a href={`/tools/${tool.id}`} class="inline-flex items-center gap-1.5 px-3 py-2 bg-white rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-sm transition-all text-sm font-medium text-gray-700 hover:text-blue-600">
          <span>{tool.icon}</span>
          {tool.label}
        </a>
      ))}
    </div>
  </section>

  <!-- Articles Grid -->
  <section class="max-w-5xl mx-auto px-4 py-6">
    <h2 class="text-lg font-bold text-gray-800 mb-4">入門記事一覧</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {beginnerPosts.map((post) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          slug={post.id}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>

  <!-- Back -->
  <section class="max-w-5xl mx-auto px-4 py-6">
    <a href="/" class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-800 font-semibold text-sm transition-colors group">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      記事一覧に戻る
    </a>
  </section>
</BaseLayout>
