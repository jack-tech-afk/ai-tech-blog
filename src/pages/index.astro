---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const categories = [
  { id: 'ai-tools', label: 'AIツール比較', icon: '🤖' },
  { id: 'saas', label: 'SaaSレビュー', icon: '☁️' },
  { id: 'gadgets', label: 'ガジェット', icon: '📱' },
  { id: 'guides', label: '使い方ガイド', icon: '📖' },
  { id: 'ranking', label: 'ランキング', icon: '🏆' },
];
---

<BaseLayout
  title="AI Tech Review - AIツール・ガジェット徹底比較"
  description="AIツール・SaaS・ガジェットの徹底比較レビューサイト。ChatGPT、Claude、Notion、最新ガジェットまで、あなたに最適なツール選びをサポートします。"
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary-600 to-indigo-700 text-white py-16">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4">
        AIツール・ガジェットを<br class="sm:hidden" />徹底比較レビュー
      </h1>
      <p class="text-lg text-blue-100 max-w-2xl mx-auto">
        最新のAIツール、SaaSサービス、ガジェットを実際に使って比較。あなたに最適なツール選びをサポートします。
      </p>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">最新記事</h2>
    {sortedPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {sortedPosts.slice(0, 6).map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
            tags={post.data.tags}
          />
        ))}
      </div>
    ) : (
      <p class="text-gray-500">記事を準備中です。</p>
    )}
  </section>

  <!-- Category Sections -->
  {categories.map((cat) => {
    const catPosts = sortedPosts.filter((p) => p.data.category === cat.id);
    if (catPosts.length === 0) return null;
    return (
      <section id={cat.id} class="max-w-5xl mx-auto px-4 py-8">
        <h2 class="text-2xl font-bold text-gray-800 mb-6">
          {cat.icon} {cat.label}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {catPosts.slice(0, 3).map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
              tags={post.data.tags}
            />
          ))}
        </div>
      </section>
    );
  })}
</BaseLayout>
