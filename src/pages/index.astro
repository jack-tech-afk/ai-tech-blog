---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const categories = [
  { id: 'ai-tools', altIds: ['AIツール'], label: 'AIツール比較', icon: '🤖', gradient: 'from-blue-500 to-indigo-600' },
  { id: 'saas', altIds: ['SaaS'], label: 'SaaSレビュー', icon: '☁️', gradient: 'from-emerald-500 to-teal-600' },
  { id: 'gadgets', altIds: ['ガジェット'], label: 'ガジェット', icon: '📱', gradient: 'from-purple-500 to-fuchsia-600' },
  { id: 'guides', altIds: ['使い方ガイド'], label: '使い方ガイド', icon: '📖', gradient: 'from-amber-400 to-orange-500' },
  { id: 'ranking', altIds: ['ランキング'], label: 'ランキング', icon: '🏆', gradient: 'from-rose-500 to-red-600' },
  { id: 'business', altIds: ['ビジネス'], label: 'ビジネス活用', icon: '💼', gradient: 'from-slate-600 to-gray-800' },
];

const totalArticles = sortedPosts.length;
---

<BaseLayout
  title="AI Tech Review - AIツール・ガジェット徹底比較"
  description="AIツール・SaaS・ガジェットの徹底比較レビューサイト。ChatGPT、Claude、Notion、最新ガジェットまで、あなたに最適なツール選びをサポートします。"
>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-primary-700 via-indigo-700 to-purple-800 text-white py-20 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.4'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;)"></div>
    <div class="max-w-5xl mx-auto px-4 text-center relative z-10">
      <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm text-sm font-medium px-4 py-2 rounded-full mb-6">
        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
        {totalArticles}本の記事を公開中
      </div>
      <h1 class="text-3xl md:text-5xl font-bold mb-5 leading-tight">
        AIツール・ガジェットを<br class="sm:hidden" />
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-200 to-purple-200">徹底比較レビュー</span>
      </h1>
      <p class="text-lg text-blue-100/90 max-w-2xl mx-auto leading-relaxed">
        最新のAIツール、SaaSサービス、ガジェットを実際に使って比較。<br class="hidden md:block" />
        あなたに最適なツール選びをサポートします。
      </p>

      <!-- Category Quick Links -->
      <div class="flex flex-wrap justify-center gap-3 mt-8">
        {categories.map((cat) => (
          <a href={`#${cat.id}`} class="inline-flex items-center gap-1.5 bg-white/10 hover:bg-white/20 backdrop-blur-sm text-white text-sm font-medium px-4 py-2 rounded-full transition-all duration-200 hover:-translate-y-0.5">
            <span>{cat.icon}</span>
            {cat.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- AI Tool Quick Access -->
  <section class="max-w-5xl mx-auto px-4 py-8">
    <h2 class="text-lg font-bold text-gray-800 mb-3">AIツール別に記事を探す</h2>
    <div class="flex flex-wrap gap-2">
      {[
        { id: 'chatgpt', label: 'ChatGPT', icon: '💬' },
        { id: 'claude', label: 'Claude', icon: '🟠' },
        { id: 'gemini', label: 'Gemini', icon: '✨' },
        { id: 'copilot', label: 'Copilot', icon: '🔷' },
        { id: 'midjourney', label: 'Midjourney', icon: '🎨' },
        { id: 'dall-e', label: 'DALL-E', icon: '🖼️' },
        { id: 'perplexity', label: 'Perplexity', icon: '🔍' },
        { id: 'cursor', label: 'Cursor', icon: '⌨️' },
      ].map((tool) => (
        <a href={`/tools/${tool.id}`} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-50 rounded-lg border border-gray-200 hover:border-blue-400 hover:bg-blue-50 transition-all text-sm font-medium text-gray-600 hover:text-blue-600">
          <span>{tool.icon}</span>
          {tool.label}
        </a>
      ))}
    </div>
  </section>

  <!-- Business Scene Quick Access -->
  <section class="max-w-5xl mx-auto px-4 py-4">
    <h2 class="text-lg font-bold text-gray-800 mb-3">💼 ビジネスシーン別に記事を探す</h2>
    <div class="flex flex-wrap gap-2">
      {[
        { id: 'presentation', label: '資料作成', icon: '📊' },
        { id: 'meeting', label: '議事録・会議', icon: '📝' },
        { id: 'email', label: 'メール効率化', icon: '✉️' },
        { id: 'idea', label: 'アイデア整理', icon: '💡' },
        { id: 'data', label: 'データ分析', icon: '📈' },
        { id: 'report', label: '日報・レポート', icon: '📋' },
        { id: 'support', label: 'カスタマー対応', icon: '🎧' },
        { id: 'collaboration', label: 'チャット効率化', icon: '💬' },
        { id: 'writing', label: 'SEO・ライティング', icon: '✍️' },
        { id: 'remote', label: 'リモートワーク', icon: '🏠' },
      ].map((item) => (
        <a href={`/business/${item.id}`} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-50 rounded-lg border border-slate-200 hover:border-slate-500 hover:bg-slate-100 transition-all text-sm font-medium text-slate-600 hover:text-slate-800">
          <span>{item.icon}</span>
          {item.label}
        </a>
      ))}
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <div class="flex items-center gap-3 mb-8">
      <div class="w-10 h-10 bg-gradient-to-br from-primary-500 to-indigo-600 rounded-xl flex items-center justify-center shadow-md">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
        </svg>
      </div>
      <div>
        <h2 class="text-2xl font-bold text-gray-800">最新記事</h2>
        <p class="text-sm text-gray-500">新しく公開された記事をチェック</p>
      </div>
    </div>
    {sortedPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedPosts.slice(0, 6).map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
            tags={post.data.tags}
          />
        ))}
      </div>
    ) : (
      <p class="text-gray-500">記事を準備中です。</p>
    )}
  </section>

  <!-- Category Sections -->
  {categories.map((cat) => {
    const catPosts = sortedPosts.filter((p) => p.data.category === cat.id || cat.altIds.includes(p.data.category));
    if (catPosts.length === 0) return null;
    return (
      <section id={cat.id} class="max-w-5xl mx-auto px-4 py-10">
        <div class="flex items-center gap-3 mb-8">
          <div class={`w-10 h-10 bg-gradient-to-br ${cat.gradient} rounded-xl flex items-center justify-center shadow-md`}>
            <span class="text-xl">{cat.icon}</span>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-800">{cat.label}</h2>
            <p class="text-sm text-gray-500">{catPosts.length}本の記事</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {catPosts.slice(0, 6).map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
              tags={post.data.tags}
            />
          ))}
        </div>
      </section>
    );
  })}

  <!-- Newsletter / CTA Section -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <div class="bg-gradient-to-br from-gray-900 to-gray-800 rounded-2xl p-8 md:p-12 text-center text-white relative overflow-hidden">
      <div class="absolute inset-0 opacity-5" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.4'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;)"></div>
      <div class="relative z-10">
        <h2 class="text-2xl md:text-3xl font-bold mb-3">
          最新のAIツール情報をチェック 🚀
        </h2>
        <p class="text-gray-300 mb-6 max-w-xl mx-auto">
          毎週更新される比較レビューで、あなたに最適なツールを見つけましょう。
        </p>
        <a href="#" class="inline-flex items-center gap-2 bg-white text-gray-900 font-bold px-8 py-3.5 rounded-xl hover:bg-gray-100 transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
          </svg>
          全記事を見る
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
