---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  image?: string;
  heroImage?: string;
  article?: boolean;
  pubDate?: string;
  updatedDate?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const props = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <SEOHead {...props} />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-CRL4DMBVB2" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-CRL4DMBVB2');
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
